  "limit": 10,
  "params": [
    "wf-1",
    "wf-2",
    "2024-01-01",
    5,
  ],
  "sql": "SELECT e."status" AS "status", COUNT(*) AS "count"
FROM "execution_entity" AS e
LEFT JOIN "workflow_entity" AS w ON w."id" = e."workflowId"
WHERE e."workflowId" IN (?, ?) AND e."startedAt" > ?
GROUP BY e."status"
HAVING COUNT(*) > ?
ORDER BY COUNT(*) DESC
LIMIT 10",
}
`;

