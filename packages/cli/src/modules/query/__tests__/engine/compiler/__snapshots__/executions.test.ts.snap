exports[`executions compiler (postgresdb) GROUP BY + HAVING GROUP BY multiple columns 1`] = `
{
  "columns": [
    "status",
    "mode",
    "count",
  ],
  "kind": "sql-only",
  "limit": 1000,
  "params": [
    "wf-1",
    "wf-2",
  ],
  "sql": "SELECT e."status" AS "status", e."mode" AS "mode", COUNT(*) AS "count"
FROM "execution_entity" AS e
LEFT JOIN "workflow_entity" AS w ON w."id" = e."workflowId"
WHERE e."workflowId" IN ($1, $2)
GROUP BY e."status", e."mode"
LIMIT 1000",
}
`;

