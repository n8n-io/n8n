		{
			"parameters": {
				"jsCode": "// Fan the same binary out across multiple items so it appears in many places\n// in the execution data. Combined with N8N_DEFAULT_BINARY_DATA_MODE=default this\n// inflates the inline base64 footprint and can also create shared references\n// after flatted serialization round-trip.\nconst out = [];\nfor (let i = 0; i < 5; i++) {\n  out.push({\n    json: { copy: i },\n    binary: $input.first().binary,\n  });\n}\nreturn out;"
			},
