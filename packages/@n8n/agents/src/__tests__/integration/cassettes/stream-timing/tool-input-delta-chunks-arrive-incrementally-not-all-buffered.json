							"input": {
								"code": "/**\n * Bubble Sort Implementation in TypeScript\n * Sorts an array in ascending order using the bubble sort algorithm\n * Time Complexity: O(n²)\n * Space Complexity: O(1)\n */\n\nfunction bubbleSort(arr: number[]): number[] {\n  const n = arr.length;\n  \n  // Outer loop for each pass\n  for (let i = 0; i < n - 1; i++) {\n    let swapped = false;\n    \n    // Inner loop for comparing adjacent elements\n    for (let j = 0; j < n - i - 1; j++) {\n      // Compare adjacent elements\n      if (arr[j] > arr[j + 1]) {\n        // Swap if they are in wrong order\n        const temp = arr[j];\n        arr[j] = arr[j + 1];\n        arr[j + 1] = temp;\n        swapped = true;\n      }\n    }\n    \n    // Optimization: if no swaps occurred, array is already sorted\n    if (!swapped) {\n      break;\n    }\n  }\n  \n  return arr;\n}\n\n// Test cases\nconst testArray1 = [64, 34, 25, 12, 22, 11, 90];\nconsole.log(\"Original array:\", testArray1);\nconsole.log(\"Sorted array:\", bubbleSort([...testArray1]));\n\nconst testArray2 = [5, 2, 8, 1, 9];\nconsole.log(\"\\nOriginal array:\", testArray2);\nconsole.log(\"Sorted array:\", bubbleSort([...testArray2]));\n\nconst testArray3 = [1, 2, 3, 4, 5];\nconsole.log(\"\\nAlready sorted array:\", testArray3);\nconsole.log(\"Sorted array:\", bubbleSort([...testArray3]));"
