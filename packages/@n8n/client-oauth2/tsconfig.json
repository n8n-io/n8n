{
	"extends": "@n8n/typescript-config/tsconfig.common.json",
	"compilerOptions": {
		"ignoreDeprecations": "6.0",
		"rootDir": ".",
		"types": ["node", "jest"],
		"baseUrl": "src",
		"paths": {
			"@/*": ["./*"]
		},
		"tsBuildInfoFile": "dist/typecheck.tsbuildinfo"
	},
	"include": ["src/**/*.ts", "test/**/*.ts"]
}
