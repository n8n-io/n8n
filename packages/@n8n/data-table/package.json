{
  "name": "@n8n/data-table",
  "version": "0.1.0",
  "scripts": {
    "clean": "rimraf dist .turbo",
    "dev": "pnpm watch",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "build:unchecked": "tsc -p tsconfig.build.json --noCheck",
    "format": "biome format --write src",
    "format:check": "biome ci src",
    "lint": "eslint . --quiet",
    "lint:fix": "eslint . --fix",
    "watch": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:dev": "vitest --silent=false"
  },
  "main": "dist/index.js",
  "module": "src/index.ts",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./src/index.ts",
      "types": "./dist/index.d.ts"
    },
    "./module": {
      "require": "./dist/data-table.module.js",
      "import": "./src/data-table.module.ts",
      "types": "./dist/data-table.module.d.ts"
    }
  },
  "dependencies": {
    "@n8n/api-types": "workspace:*",
    "@n8n/backend-common": "workspace:*",
    "@n8n/config": "workspace:*",
    "@n8n/db": "workspace:*",
    "@n8n/decorators": "workspace:*",
    "@n8n/di": "workspace:*",
    "@n8n/permissions": "workspace:*",
    "@n8n/typeorm": "workspace:*",
    "csv-parse": "catalog:",
    "express": "catalog:",
    "luxon": "catalog:",
    "multer": "^2.2.0",
    "n8n-core": "workspace:*",
    "n8n-workflow": "workspace:*",
    "nanoid": "catalog:"
  },
  "devDependencies": {
    "@n8n/backend-test-utils": "workspace:*",
    "@n8n/typescript-config": "workspace:*",
    "@n8n/vitest-config": "workspace:*",
    "@types/express": "catalog:",
    "@types/luxon": "catalog:",
    "@types/multer": "^2.1.0",
    "@vitest/coverage-v8": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vitest-mock-extended": "catalog:"
  },
  "license": "LicenseRef-n8n-sustainable-use"
}
