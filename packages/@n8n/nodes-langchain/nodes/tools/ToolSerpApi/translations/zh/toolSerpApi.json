				},
				"google_domain": {
					"displayName": "Google域名",
					"description": "定义用于搜索的域名。前往<a href=\"https://serpapi.com/google-domains\">Google域名页面</a>查看完整支持域名列表。"
				},
				"hl": {
					"displayName": "语言",
					"description": "定义要使用的语言。使用两位字母的语言代码（例如，`en`表示英语，`es`表示西班牙语，`fr`表示法语）。前往<a href=\"https://serpapi.com/google-languages\">Google语言页面</a>查看支持语言的完整列表。"
				}
			}
		}
