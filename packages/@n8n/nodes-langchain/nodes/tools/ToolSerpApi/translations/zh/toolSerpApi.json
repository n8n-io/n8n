				},
				"device": {
					"displayName": "设备",
					"description": "用于获取结果的设备",
					"options": {
						"desktop": {
							"displayName": "桌面版"
						},
						"mobile": {
							"displayName": "移动端"
						},
						"tablet": {
							"displayName": "平板电脑"
						}
					}
				},
				"no_cache": {
					"displayName": "显式数组",
