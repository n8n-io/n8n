			"name": "Get many messages",
			"webhookId": "baacbe6e-2681-4580-9419-f5d7bb5e8a15"
		},
		{
			"parameters": {
				"promptType": "define",
				"text": "=<subject>{{ $json.subject }}</subject>\n<email-body>\n{{ $json.html }}\n</email-body>",
				"hasOutputParser": true,
				"options": {
					"systemMessage": "You are a helpful assistant, that extracts action items and priorities from emails.\nOnly put action items in there that are assigned to me.\nDon't put calendar invites in the action items or priorities -- they are added to my calendar automatically and will review them separately"
				}
			},
			"type": "@n8n/n8n-nodes-langchain.agent",
			"typeVersion": 3,
			"position": [1104, 80],
			"id": "d86d05ba-82a4-42a8-b61b-993289016f52",
			"name": "AI Agent"
