					"value": "claude-sonnet-4-5-20250929",
					"cachedResultName": "Claude Sonnet 4.5"
				},
				"options": {}
			},
			"type": "@n8n/n8n-nodes-langchain.lmChatAnthropic",
			"typeVersion": 1.3,
			"position": [1120, 304],
			"id": "baeaccca-42c1-433b-a83a-8cb06bc6dee3",
			"name": "Anthropic Chat Model"
		},
		{
			"parameters": {
				"jsonSchemaExample": "{\n\t\"actionItems\": [\"action item 1\", \"action item 2\"],\n\t\"priorities\": [\"priority 1\", \"priority 2\"]\n}"
