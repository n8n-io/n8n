			"typeVersion": 1.3,
			"position": [1248, 304],
			"id": "2cb9cb25-9cbb-4422-a2bb-d471373d4da6",
			"name": "Structured Output Parser"
		},
		{
			"parameters": {
				"mode": "combine",
				"combineBy": "combineByPosition",
				"options": {}
			},
			"type": "n8n-nodes-base.merge",
			"typeVersion": 3.2,
			"position": [1456, -48],
			"id": "3fa29406-d87b-41a7-98dc-0db0174a6c10",
			"name": "Merge"
		},
