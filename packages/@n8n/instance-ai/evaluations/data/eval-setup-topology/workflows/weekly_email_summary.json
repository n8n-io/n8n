			"name": "Aggregate"
		},
		{
			"parameters": {
				"promptType": "define",
				"text": "=Convert the following in to a nicely organised email that lists the action items and/or priorities that I have, with the sender and subject. Make sure to output HTML (and only the HTML, **DO NOT include markdown preamble or code-backtics**)\nOnly include emails that have an action item or a priority for me to look at.\n\n{{ $json.toJsonString() }}",
				"options": {}
			},
			"type": "@n8n/n8n-nodes-langchain.agent",
