{
	"name": "IF Workflow",
	"nodes": [
		{
			"id": "1",
			"name": "Manual Trigger",
			"type": "n8n-nodes-base.manualTrigger",
			"typeVersion": 1,
			"position": [0, 0],
			"parameters": {}
		},
		{
			"id": "2",
			"name": "IF",
			"type": "n8n-nodes-base.if",
			"typeVersion": 2,
			"position": [200, 0],
			"parameters": {
				"conditions": {
					"options": {
						"version": 2,
						"caseSensitive": true,
						"typeValidation": "loose"
					},
					"combinator": "and",
					"conditions": [
						{
							"operator": {
								"type": "string",
								"operation": "equals"
							},
							"leftValue": "={{ $json.status }}",
							"rightValue": "active"
						}
					]
				}
			}
		},
		{
			"id": "3",
			"name": "True Branch",
			"type": "n8n-nodes-base.set",
			"typeVersion": 3,
			"position": [400, -100],
			"parameters": {}
		},
		{
			"id": "4",
			"name": "False Branch",
			"type": "n8n-nodes-base.set",
			"typeVersion": 3,
			"position": [400, 100],
			"parameters": {}
		}
	],
	"connections": {
		"Manual Trigger": {
			"main": [[{ "node": "IF", "type": "main", "index": 0 }]]
		},
		"IF": {
			"main": [
				[{ "node": "True Branch", "type": "main", "index": 0 }],
				[{ "node": "False Branch", "type": "main", "index": 0 }]
			]
		}
	}
}
