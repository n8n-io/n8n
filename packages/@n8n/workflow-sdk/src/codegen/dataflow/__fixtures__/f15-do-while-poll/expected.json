{
	"name": "Batch Poll",
	"nodes": [
		{
			"id": "node-0",
			"name": "Manual Trigger",
			"type": "n8n-nodes-base.manualTrigger",
			"typeVersion": 1,
			"position": [0, 0],
			"parameters": {}
		},
		{
			"id": "node-1",
			"name": "Split In Batches",
			"type": "n8n-nodes-base.splitInBatches",
			"typeVersion": 3,
			"position": [200, 0],
			"parameters": {
				"batchSize": 1
			}
		},
		{
			"id": "node-2",
			"name": "Check Status",
			"type": "n8n-nodes-base.httpRequest",
			"typeVersion": 4,
			"position": [400, 0],
			"parameters": {
				"url": "https://api.example.com/status"
			}
		}
	],
	"connections": {
		"Manual Trigger": {
			"main": [[{ "node": "Split In Batches", "type": "main", "index": 0 }]]
		},
		"Split In Batches": {
			"main": [[], [{ "node": "Check Status", "type": "main", "index": 0 }]]
		},
		"Check Status": {
			"main": [[{ "node": "Split In Batches", "type": "main", "index": 0 }]]
		}
	}
}
