{
	"name": "Loop Try Catch",
	"nodes": [
		{
			"id": "node-0",
			"name": "Manual Trigger",
			"type": "n8n-nodes-base.manualTrigger",
			"typeVersion": 1,
			"position": [0, 0],
			"parameters": {}
		},
		{
			"id": "node-1",
			"name": "HTTP Request",
			"type": "n8n-nodes-base.httpRequest",
			"typeVersion": 4,
			"position": [200, 0],
			"parameters": {
				"url": "https://api.example.com/users"
			}
		},
		{
			"id": "node-2",
			"name": "Split In Batches",
			"type": "n8n-nodes-base.splitInBatches",
			"typeVersion": 3,
			"position": [400, 0],
			"parameters": {
				"batchSize": 1
			}
		},
		{
			"id": "node-3",
			"name": "Send Email",
			"type": "n8n-nodes-base.emailSend",
			"typeVersion": 2,
			"position": [600, 0],
			"parameters": {
				"toEmail": "user@example.com"
			},
			"onError": "continueErrorOutput"
		},
		{
			"id": "node-4",
			"name": "Log Error",
			"type": "n8n-nodes-base.set",
			"typeVersion": 3,
			"position": [800, 0],
			"parameters": {}
		},
		{
			"id": "node-5",
			"name": "Summary",
			"type": "n8n-nodes-base.set",
			"typeVersion": 3,
			"position": [1000, 0],
			"parameters": {}
		}
	],
	"connections": {
		"Manual Trigger": {
			"main": [[{ "node": "HTTP Request", "type": "main", "index": 0 }]]
		},
		"HTTP Request": {
			"main": [[{ "node": "Split In Batches", "type": "main", "index": 0 }]]
		},
		"Split In Batches": {
			"main": [
				[{ "node": "Summary", "type": "main", "index": 0 }],
				[{ "node": "Send Email", "type": "main", "index": 0 }]
			]
		},
		"Send Email": {
			"main": [
				[{ "node": "Split In Batches", "type": "main", "index": 0 }],
				[{ "node": "Log Error", "type": "main", "index": 0 }]
			]
		},
		"Log Error": {
			"main": [[{ "node": "Split In Batches", "type": "main", "index": 0 }]]
		}
	}
}
