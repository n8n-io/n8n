{
	"extends": ["./tsconfig.json", "@n8n/typescript-config/tsconfig.build.go.json"],
	"compilerOptions": {
		"composite": true,
		"module": "CommonJS",
		"moduleResolution": "bundler",
		"noEmit": false,
		"rootDir": "src",
		"outDir": "dist"
	},
	"include": ["src/server/**/*.ts", "src/apps-manifest.ts", "src/telemetry-contract.ts"],
	"exclude": ["src/**/*.test.ts"]
}
