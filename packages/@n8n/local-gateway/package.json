{
  "name": "@n8n/local-gateway",
  "version": "0.1.0",
  "description": "n8n Assistant desktop app",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json --noEmit && vite build",
    "build:unchecked": "rimraf dist && vite build",
    "lint": "eslint . --quiet",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "dev": "vite",
    "start": "electron dist/main/index.js",
    "dist:mac": "pnpm build && electron-builder --mac --config electron-builder.config.js",
    "dist:win": "pnpm build && electron-builder --win --config electron-builder.config.js",
    "format": "biome format --write src",
    "format:check": "biome ci src",
    "clean": "rimraf dist out .turbo",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:dev": "vitest --silent=false"
  },
  "dependencies": {
    "@n8n/api-types": "workspace:*",
    "@n8n/computer-use": "workspace:*",
    "@n8n/design-system": "workspace:*",
    "@n8n/i18n": "workspace:*",
    "electron-store": "^8.2.0",
    "vue": "catalog:frontend"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@iconify/json": "^2.2.349",
    "@n8n/eslint-config": "workspace:*",
    "@n8n/typescript-config": "workspace:*",
    "@n8n/vitest-config": "workspace:*",
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "catalog:frontend",
    "@vitest/coverage-v8": "catalog:",
    "electron": "^41.3.0",
    "electron-builder": "^26.9.0",
    "rimraf": "catalog:",
    "sass-embedded": "catalog:",
    "unplugin-icons": "catalog:frontend",
    "vite": "catalog:",
    "vite-plugin-electron": "catalog:",
    "vite-svg-loader": "catalog:frontend",
    "vitest": "catalog:"
  },
  "license": "LicenseRef-n8n-sustainable-use"
}
