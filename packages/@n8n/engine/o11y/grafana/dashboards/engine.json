{
	"annotations": { "list": [] },
	"editable": true,
	"graphTooltip": 1,
	"panels": [
		{
			"title": "Overview",
			"type": "row",
			"gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
			"collapsed": false,
			"panels": []
		},
		{
			"title": "Execution Throughput",
			"type": "timeseries",
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
			"datasource": "Prometheus",
			"targets": [
				{
					"expr": "sum by (status) (increase(execution_total[5m]))",
					"legendFormat": "{{status}}",
					"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "short",
					"custom": { "drawStyle": "line", "fillOpacity": 10 }
				},
				"overrides": []
			}
		},
		{
			"title": "Active Executions",
			"type": "stat",
			"gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
			"datasource": "Prometheus",
			"targets": [
				{
					"expr": "sum(execution_active)",
					"legendFormat": "active",
					"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": {
					"color": { "mode": "thresholds" },
					"thresholds": {
						"steps": [
							{ "color": "green", "value": null },
							{ "color": "yellow", "value": 50 },
							{ "color": "red", "value": 100 }
						]
					}
				},
				"overrides": []
			}
		},
		{
			"title": "Execution Duration p95",
			"type": "stat",
			"gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
			"datasource": "Prometheus",
			"targets": [
				{
					"expr": "histogram_quantile(0.95, rate(execution_duration_ms_bucket[5m]))",
					"legendFormat": "p95",
					"refId": "A"
				}
			],
			"fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] }
		},
		{
			"title": "Error Rate",
			"type": "timeseries",
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
			"datasource": "Prometheus",
			"targets": [
				{
					"expr": "sum by (classification) (increase(errors_total[5m]))",
					"legendFormat": "{{classification}}",
					"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "short",
					"custom": { "drawStyle": "line", "fillOpacity": 10 }
				},
				"overrides": []
			}
		},
		{
			"title": "API",
			"type": "row",
			"gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
			"collapsed": false,
			"panels": []
		},
		{
			"title": "API Requests by Path",
			"type": "timeseries",
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
			"datasource": "Prometheus",
			"targets": [
				{
					"expr": "sum by (path) (increase(api_requests_total[5m]))",
					"legendFormat": "{{path}}",
					"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "short",
					"custom": { "drawStyle": "line", "fillOpacity": 10 }
				},
				"overrides": []
			}
		},
		{
			"title": "API Latency p95 by Path",
			"type": "timeseries",
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
			"datasource": "Prometheus",
			"targets": [
				{
					"expr": "histogram_quantile(0.95, sum by (path, le) (rate(api_request_duration_ms_bucket[5m])))",
					"legendFormat": "{{path}}",
					"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "ms",
					"custom": { "drawStyle": "line", "fillOpacity": 10 }
				},
				"overrides": []
			}
		},
		{
			"title": "API Error Rate (4xx/5xx)",
			"type": "timeseries",
			"gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
			"datasource": "Prometheus",
			"targets": [
				{
					"expr": "sum by (path, status_code) (increase(api_requests_total{status_code=~\"4..|5..\"}[5m]))",
					"legendFormat": "{{path}} {{status_code}}",
					"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "short",
					"custom": { "drawStyle": "line", "fillOpacity": 10 }
				},
				"overrides": []
			}
		},
