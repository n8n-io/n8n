			"title": "Top Workflows by Execution Count",
			"type": "bargauge",
			"gridPos": { "h": 8, "w": 8, "x": 16, "y": 75 },
			"datasource": "Prometheus",
			"targets": [
				{
					"expr": "topk(10, sum by (workflow_id) (execution_duration_ms_count))",
					"legendFormat": "{{workflow_id}}",
					"refId": "A"
