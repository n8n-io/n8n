				"overrides": []
			},
			"options": {
				"orientation": "horizontal",
				"displayMode": "gradient",
				"reduceOptions": { "calcs": ["lastNotNull"] }
			}
		},
		{
			"title": "Resources",
			"type": "row",
			"gridPos": { "h": 1, "w": 24, "x": 0, "y": 83 },
			"collapsed": false,
			"panels": []
