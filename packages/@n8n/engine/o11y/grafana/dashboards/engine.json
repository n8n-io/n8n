		{
			"title": "Redis Relay Latency p95",
			"type": "stat",
			"gridPos": { "h": 4, "w": 6, "x": 18, "y": 57 },
			"datasource": "Prometheus",
			"targets": [
				{
					"expr": "histogram_quantile(0.95, sum by (le) (rate(redis_relay_latency_ms_bucket[5m])))",
					"legendFormat": "p95",
