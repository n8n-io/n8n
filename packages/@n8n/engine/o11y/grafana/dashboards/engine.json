			"title": "Step Duration p50 / p95",
			"type": "timeseries",
			"gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
			"datasource": "Prometheus",
			"targets": [
				{
					"expr": "histogram_quantile(0.5, sum by (le) (rate(step_execution_duration_ms_bucket[5m])))",
					"legendFormat": "p50",
					"refId": "A"
				},
				{
					"expr": "histogram_quantile(0.95, sum by (le) (rate(step_execution_duration_ms_bucket[5m])))",
					"legendFormat": "p95",
					"refId": "B"
