			"title": "Steps",
			"type": "row",
			"gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
			"collapsed": false,
			"panels": []
		},
		{
			"title": "Step Throughput",
			"type": "timeseries",
			"gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
			"datasource": "Prometheus",
			"targets": [
				{
					"expr": "sum by (status) (increase(step_execution_total[5m]))",
					"legendFormat": "{{status}}",
					"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "short",
					"custom": { "drawStyle": "line", "fillOpacity": 10 }
				},
				"overrides": []
			}
		},
