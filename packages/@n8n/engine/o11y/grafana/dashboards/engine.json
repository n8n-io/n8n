			"datasource": "Prometheus",
			"targets": [
				{
					"expr": "rate(process_cpu_seconds_total{job=~\"engine|engine-dev\"}[5m])",
					"legendFormat": "{{instance_name}}",
					"refId": "A"
				}
			],
			"fieldConfig": {
				"defaults": {
					"unit": "percentunit",
