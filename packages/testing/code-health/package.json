{
	"name": "@n8n/code-health",
	"private": true,
	"version": "0.1.0",
	"description": "Static analysis and code quality enforcement for the n8n monorepo",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"bin": {
		"code-health": "dist/cli.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"clean": "rimraf dist .turbo",
		"check": "tsx src/cli.ts",
		"build": "tsc -p tsconfig.build.json",
		"build:unchecked": "tsc -p tsconfig.build.json --noCheck",
		"dev": "tsc --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"format": "biome format --write .",
		"format:check": "biome ci .",
		"lint": "eslint . --quiet",
		"lint:fix": "eslint . --fix",
		"typecheck": "tsc --noEmit"
	},
	"license": "MIT",
	"dependencies": {
		"@n8n/rules-engine": "workspace:*",
		"@n8n/vitest-config": "workspace:*",
		"fast-glob": "catalog:",
		"ts-morph": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"yaml": "catalog:"
	},
  "devDependencies": {
		"@vitest/coverage-v8": "catalog:",
		"vitest": "catalog:"
  }
}
