{
	"extends": "../../../tsconfig.json",
	"compilerOptions": {
		"module": "NodeNext",
    	"moduleResolution": "NodeNext",
		"skipLibCheck": true,
		"types": [],
		"paths": {
			"psl": ["../../../node_modules/psl/index.d.ts"]
		},
		"outDir": "dist",
		"rootDir": "src",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"lib": ["ES2022"],
		"target": "ES2022",
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": ["src/**/*"],
	"exclude": ["dist", "node_modules", "**/__tests__/**"]
}
