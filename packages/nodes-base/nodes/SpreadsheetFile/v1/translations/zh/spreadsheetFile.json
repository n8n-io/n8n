						"value": {
							"displayName": "值",
							"options": {
								"enabled": {
									"displayName": "已启用",
									"description": "从文件读取时是否跳过错误记录"
								},
								"maxSkippedRecords": {
									"displayName": "最大跳过记录数",
									"description": "可跳过的最大记录数，超过此限制将抛出错误。设置为-1可取消限制。"
								}
							}
						}
					},
					"values": {
						"value": {
							"displayName": "值",
							"options": {
								"enabled": {
									"displayName": "已启用",
									"description": "从文件读取时是否跳过错误记录"
								},
								"maxSkippedRecords": {
									"displayName": "最大跳过记录数",
									"description": "可跳过的最大记录数，超过此限制将抛出错误。设置为-1可取消限制。"
								}
							}
						},
						"skipRecordsWithErrors": {
							"displayName": "跳过错误记录"
						}
					}
				},
				"compression": {
					"displayName": "压缩",
					"description": "是否应用压缩"
				},
				"fileName": {
					"displayName": "文件名",
					"description": "二进制数据中设置的文件名。默认将使用\"spreadsheet.&lt;文件格式&gt;\"。"
				}
			}
		}
