					"placeholder": "例如 ,"
				},
				"encoding": {
					"displayName": "编码",
					"options": {
						"ascii": {
							"displayName": "ASCII"
						},
						"latin1": {
							"displayName": "拉丁1编码"
						},
						"ucs-2": {
							"displayName": "UCS-2"
						},
						"ucs2": {
							"displayName": "UCS2"
						},
						"utf-8": {
							"displayName": "UTF-8"
						},
						"utf16le": {
							"displayName": "UTF16LE"
