					"displayName": "年"
				},
				"months": {
					"displayName": "月"
				},
				"weeks": {
					"displayName": "周"
				},
				"days": {
					"displayName": "天"
				},
				"hours": {
					"displayName": "小时"
				},
				"minutes": {
					"displayName": "分钟"
				},
				"seconds": {
					"displayName": "秒"
				},
				"milliseconds": {
					"displayName": "毫秒"
				}
			}
		}
	}
