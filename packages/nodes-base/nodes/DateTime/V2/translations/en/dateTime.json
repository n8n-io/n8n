			"displayName": "Operation",
			"options": {
				"addToDate": {
					"displayName": "Add to a Date"
				},
				"extractDate": {
					"displayName": "Extract Part of a Date"
				},
				"formatDate": {
					"displayName": "Format a Date"
				},
				"getCurrentDate": {
					"displayName": "Get Current Date"
				},
				"getTimeBetweenDates": {
					"displayName": "Get Time Between Dates"
				},
				"roundDate": {
					"displayName": "Round a Date"
