				},
				"include_mounted_folders": {
					"displayName": "包含已挂载文件夹",
					"description": "是否在结果中包含已挂载文件夹下的条目，包括应用文件夹、共享文件夹和团队文件夹。此字段的默认值为True。"
				},
				"include_non_downloadable_files": {
					"displayName": "包含不可下载文件",
					"description": "是否包含不可下载的文件，例如Google文档。此字段默认值为True。"
				},
				"recursive": {
					"displayName": "递归",
					"description": "是否将列出文件夹操作递归应用于所有子文件夹，且响应将包含所有子文件夹的内容。此字段的默认值为False。"
				}
			}
