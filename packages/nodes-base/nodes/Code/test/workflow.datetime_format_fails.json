				"mode": "runOnceForEachItem",
				"jsCode": "// This should work according to docs but throws:\n// \"DateTime.now(...).format is not a function\"\n$input.item.json.formatted = DateTime.now().format('yyyy-MM-dd HH:mm:ss');\nreturn $input.item;"
			},
			"id": "code-format-method",
			"name": "Code with DateTime.format()",
