			"position": [200, 0]
		},
		{
			"parameters": {
				"mode": "runOnceForEachItem",
				"jsCode": "// Workaround: use native Luxon .toFormat() instead\n$input.item.json.formatted = DateTime.now().toFormat('yyyy-MM-dd HH:mm:ss');\nreturn $input.item;"
			},
			"id": "code-toformat-method",
			"name": "Code with DateTime.toFormat() (workaround)",
