					"displayName": "消息",
					"description": "发送消息"
				}
			}
		},
		"operation": {
			"displayName": "操作",
			"options": {
				"sendTemplate": {
					"displayName": "发送模板",
					"description": "基于模板发送消息"
				},
				"sendHtml": {
					"displayName": "发送HTML",
					"description": "基于HTML发送消息"
				}
			}
		},
		"template": {
			"displayName": "模板名称或ID",
