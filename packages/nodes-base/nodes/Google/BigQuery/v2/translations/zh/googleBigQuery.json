				},
				"dryRun": {
					"displayName": "试运行",
					"description": "设置为true时BigQuery不运行作业。相反，如果查询有效，BigQuery会返回作业的统计信息，例如将处理多少字节。如果查询无效，则返回错误。"
				},
				"includeSchema": {
					"displayName": "输出中包含架构",
