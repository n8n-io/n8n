				},
				"location": {
					"displayName": "位置（区域）",
					"description": "数据存储和处理的位置或区域。存储和分析的定价也由数据位置和预留决定，更多信息请<a href=\"https://cloud.google.com/bigquery/docs/locations\" target=\"_blank\">点击此处</a>。",
					"placeholder": "例如：europe-west3"
				},
				"maximumBytesBilled": {
					"displayName": "最大计费字节数",
					"description": "限制此查询的计费字节数。计费字节数超过此限制的查询将失败（且不会产生费用）。使用<a href=\"https://developers.google.com/discovery/v1/type-format?utm_source=cloud.google.com&utm_medium=referral\" target=\"_blank\">Int64Value</a>格式的字符串"
				},
				"maxResults": {
					"displayName": "每页最大结果数",
					"description": "每页返回的最大结果数量。这在处理大型数据集时特别有用。它不会影响返回的结果总数，例如表中的行数。您可以在SQL查询中使用LIMIT来限制返回的行数。"
				},
				"timeoutMs": {
					"displayName": "超时时间",
					"description": "指定客户端愿意等待查询完成的最大时间（毫秒）。请注意，调用不保证会等待指定的超时时间；即使查询未完成，通常也会在大约200秒（200,000毫秒）后返回。"
				},
