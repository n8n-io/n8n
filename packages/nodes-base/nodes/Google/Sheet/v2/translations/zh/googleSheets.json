				},
				"usePathForKeyRow": {
					"displayName": "将表头名称用作JSON路径",
					"description": "是否希望将表头作为路径进行匹配。例如，行表头“category.name”将匹配“category”对象并从中获取“name”字段。默认情况下，“category.name”将匹配具有确切名称的字段，而非嵌套对象。"
				},
				"valueInputMode": {
					"displayName": "数值输入模式",
					"description": "确定应如何解析数据",
					"options": {
						"RAW": {
							"displayName": "返回完整的电子邮件消息数据，其中正文内容以base64url编码字符串的形式存储在raw字段中；payload字段未被使用",
							"description": "这些值将不会被解析，会按原样存储"
						},
						"USER_ENTERED": {
							"displayName": "用户输入",
							"description": "这些值将按照用户在界面中输入的方式进行解析。数字将保持为数字，但字符串可能会根据在Google Sheets界面中向单元格输入文本时应用的相同规则转换为数字、日期等。"
						}
					}
				},
				"valueRenderMode": {
					"displayName": "值渲染模式",
					"description": "决定输出中应如何渲染值",
					"options": {
						"FORMATTED_VALUE": {
							"displayName": "格式化值",
							"description": "数值将根据单元格的格式在回复中计算并格式化。格式化基于电子表格的区域设置，而非请求用户的区域设置。例如，如果A1单元格为1.23，A2单元格为=A1且格式设置为货币，则A2将返回“$1.23”。"
						},
						"FORMULA": {
							"displayName": "公式",
							"description": "数值将不会被计算。回复将包含公式。例如，如果A1是1.23，A2是=A1且格式化为货币，那么A2将返回“=A1”。"
						},
						"UNFORMATTED_VALUE": {
							"displayName": "未格式化的值",
							"description": "数值会被计算，但在返回时不会被格式化。例如，如果A1是1.23，A2是=A1且格式化为货币，那么A2将返回数字1.23。"
						}
					}
				},
				"locale": {
					"displayName": "语言区域",
