				"fromDateTime": {
					"displayName": "之后",
					"description": "返回在指定日期时间或之后开始的通话。如未提供，则从最早的通话开始列出。对于由Gong录制的网络会议通话，该日期表示其预定时间；否则，表示其实际开始时间。",
					"placeholder": "例如：2018-02-18T02:30:00-07:00 或 2018-02-18T08:00:00Z"
				},
				"toDateTime": {
					"displayName": "之前",
					"description": "Returns calls that started up to but excluding specified date and time. If not provided, list ends with most recent call. For web-conference calls recorded by Gong, the date denotes its scheduled time, otherwise, it denotes its actual start time.",
					"placeholder": "例如：2018-02-18T02:30:00-07:00 或 2018-02-18T08:00:00Z"
				},
				"workspaceId": {
					"displayName": "工作区ID",
					"description": "仅返回属于此工作空间的通话",
					"placeholder": "例如 623457276584334"
				},
				"callIds": {
					"displayName": "通话ID",
					"description": "待筛选的通话ID列表",
					"placeholder": "例如：7782342274025937895"
				},
				"primaryUserIds": {
					"displayName": "组织者",
