								},
								"batchInterval": {
									"displayName": "批次间隔（毫秒）",
									"description": "每批请求之间的时间间隔（毫秒）。0表示禁用。"
								}
							}
						}
					},
					"values": {
						"batch": {
							"displayName": "批处理",
							"options": {
								"batchSize": {
									"displayName": "每批处理项数",
									"description": "输入将被分批处理以限制请求速率。-1表示禁用。0将被视为1。"
								},
								"batchInterval": {
									"displayName": "批次间隔（毫秒）",
									"description": "每批请求之间的时间间隔（毫秒）。0表示禁用。"
								}
							}
						},
						"batching": {
							"displayName": "批处理",
							"placeholder": "添加批处理"
						}
					}
				},
