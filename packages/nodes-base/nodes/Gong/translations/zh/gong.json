					"placeholder": "例如：2018-02-18T02:30:00-07:00 或 2018-02-18T08:00:00Z"
				},
				"userIds": {
					"displayName": "用户ID",
					"description": "Gong用户唯一数字标识符集合（最多20位数字）",
					"placeholder": "例如：7782342274025937895"
