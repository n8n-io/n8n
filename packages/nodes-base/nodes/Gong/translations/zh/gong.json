				"proxy": {
					"displayName": "代理",
					"description": "要使用的HTTP代理。如需身份验证，可按以下格式定义：http://用户名:密码@代理地址:端口",
					"placeholder": "例如：http://myproxy:3128"
				},
				"timeout": {
					"displayName": "超时时间",
					"description": "等待服务器发送响应头（并开始响应体）的超时时间（毫秒），超时则中止请求"
