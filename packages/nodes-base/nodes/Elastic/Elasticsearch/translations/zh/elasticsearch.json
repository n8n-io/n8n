					"placeholder": "[0]{\n  \"mappings\": {\n    \"properties\": {\n      \"field1\": { \"type\": \"text\" }\n    }\n  }\n}"
				},
				"master_timeout": {
					"displayName": "主节点超时",
					"description": "等待主节点连接的时间。如果在超时前未收到响应，请求将失败并返回错误。默认为<code>1m</code>。请参阅<a href=\"https://www.elastic.co/guide/en/elasticsearch/reference/current/common-options.html#time-units\">Elasticsearch时间单位参考</a>"
				},
				"settings": {
					"displayName": "设置",
					"description": "索引的配置选项，作为<a href=\"https://www.elastic.co/guide/en/elasticsearch/reference/current/index-modules.html#index-modules-settings\">索引设置对象</a>",
					"placeholder": "[0]{\n  \"settings\": {\n    \"index\": {\n      \"number_of_shards\": 3,\n      \"number_of_replicas\": 2\n    }\n  }\n}"
				},
				"wait_for_active_shards": {
					"displayName": "等待活动分片",
					"description": "在继续操作之前必须处于活动状态的分片副本数量。设置为<code>all</code>或任何不超过索引总分片数的正整数。默认值：1（主分片）。"
				},
				"allow_no_indices": {
					"displayName": "允许无索引",
					"description": "如果设为false，当以下任一目标仅指向缺失/已关闭的索引时返回错误：通配符表达式、索引别名或<code>_all</code>值。默认为true。"
				},
				"expand_wildcards": {
					"displayName": "展开通配符",
					"description": "通配符表达式可匹配的索引类型。默认为<code>open</code>",
					"options": {
						"all": {
							"displayName": "全部"
						},
						"closed": {
							"displayName": "已关闭"
						},
						"hidden": {
							"displayName": "隐藏"
						},
						"none": {
							"displayName": "无"
						},
						"open": {
							"displayName": "打开"
						}
					}
				},
				"flat_settings": {
					"displayName": "扁平化设置",
