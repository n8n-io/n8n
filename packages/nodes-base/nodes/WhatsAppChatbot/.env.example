# Archivo .env de Ejemplo
# Copia este archivo como .env y completa con tus credenciales reales

# WhatsApp Business API
WHATSAPP_API_TOKEN=your_permanent_access_token_here
WHATSAPP_PHONE_ID=1234567890123456
WHATSAPP_BUSINESS_ACCOUNT_ID=9876543210

# Webhook (Opcional pero recomendado)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=my_super_secure_webhook_token_12345
WHATSAPP_WEBHOOK_URL=https://tu-n8n-instance.com/webhook/whatsapp

# OpenAI (Opcional - para respuestas con IA)
OPENAI_API_KEY=sk-your_openai_key_here
OPENAI_MODEL=gpt-3.5-turbo

# Base de Datos (Opcional - para guardar historial)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=whatsapp_chatbot
DB_USER=postgres
DB_PASSWORD=your_db_password

# Logging y Debug
DEBUG=true
LOG_LEVEL=info

# Configuración de Respuestas
DEFAULT_RESPONSE=Gracias por tu mensaje. Nos contactaremos pronto.
ENABLE_AI_RESPONSES=true
SAVE_TO_DATABASE=true

# Números de Teléfono de Prueba (para testing)
TEST_PHONE_NUMBER=+599xxxxxxx
TEST_BUSINESS_NUMBER=599xxxxxxx
