{
	"header": {
		"displayName": "TimescaleDB",
		"description": "在TimescaleDB中添加和更新数据"
	},
	"nodeView": {
		"operation": {
			"displayName": "操作",
			"options": {
				"executeQuery": {
					"displayName": "执行查询",
					"description": "执行SQL查询"
				},
				"insert": {
					"displayName": "插入",
					"description": "在数据库中插入行"
				},
				"update": {
					"displayName": "更新",
					"description": "更新数据库中的行"
				}
			}
		},
		"query": {
			"displayName": "查询",
