		"columns": {
			"displayName": "列",
			"description": "以逗号分隔的属性列表，这些属性将用作要更新行的列",
			"placeholder": "名称,描述"
		},
		"updateKey": {
			"displayName": "更新键",
			"description": "决定数据库中哪些行应被更新的属性名称。通常为“id”。"
		},
		"returnFields": {
			"displayName": "返回字段",
			"description": "操作将返回的字段列表，以逗号分隔"
		},
