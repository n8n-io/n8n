					"options": {
						"independently": {
							"displayName": "独立地",
							"description": "独立执行每个查询"
						},
						"multiple": {
							"displayName": "多重查询",
							"description": "<b>默认</b>。一次性向数据库发送多个查询。"
						},
						"transaction": {
							"displayName": "交易",
							"description": "在单个事务中执行所有查询"
						}
					}
				},
				"queryParams": {
					"displayName": "查询参数",
					"description": "逗号分隔的属性列表，将用作查询参数",
