					"displayName": "Execute SQL",
					"description": "Execute an SQL"
				},
				"insert": {
					"displayName": "Insert",
					"description": "Insert rows in a table"
				},
				"upsert": {
					"displayName": "Insert or Update",
					"description": "Insert or update rows in a table"
				},
				"select": {
					"displayName": "Select",
					"description": "Select rows from a table"
