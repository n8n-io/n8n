// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`N8nEmptyState > rendering > should render correctly with an icon cluster 1`] = `
"<div class="container bordered" data-variant="empty" data-test-id="empty-state">
  <div class="visual">
    <div class="cluster" data-test-id="empty-state-cluster"><span class="tile tile-left"><n8n-icon-stub icon="key-round" strokewidth="1.5" size="20" spin="false" color="foreground-xdark"></n8n-icon-stub></span><span class="tile tile-center"><n8n-icon-stub icon="circle-ellipsis" strokewidth="1.5" size="20" spin="false" color="foreground-xdark"></n8n-icon-stub></span><span class="tile tile-right"><n8n-icon-stub icon="vault" strokewidth="1.5" size="20" spin="false" color="foreground-xdark"></n8n-icon-stub></span></div>
  </div>
  <div class="text">
    <n8n-text-stub color="text-dark" bold="true" size="large" compact="false" tag="h3" class="title"></n8n-text-stub>
    <n8n-text-stub color="text-base" bold="false" size="medium" compact="false" tag="span"></n8n-text-stub>
  </div>
  <div class="actions">
    <n8n-button-stub href="https://docs.n8n.io/external-secrets/" variant="ghost" size="large" loading="false" icononly="false" disabled="false" class="" target="_blank" data-test-id="empty-state-learn-more"></n8n-button-stub>
    <n8n-button-stub label="Add secrets store" variant="solid" size="large" loading="false" icononly="false" disabled="false" class="" data-test-id="empty-state-button"></n8n-button-stub>
  </div>
  <!--v-if-->
</div>"
`;
