# Local n8n runtime settings for the video clip workflow.
# Copy this file to .env.video-clip and fill in the real Doubao/Volcengine values.

VIDEO_CLIP_REPO_DIR=/Users/stephenqiu/Desktop/Repository/n8n
VIDEO_CLIP_JOBS_DIR=/tmp/n8n-video-jobs

# Required so workflow expressions can read $env.* values.
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# Required so Code nodes can save uploads and run the local composer script.
NODE_FUNCTION_ALLOW_BUILTIN=fs,child_process

# Doubao/Volcengine TTS settings.
DOUBAO_TTS_URL=
DOUBAO_TTS_API_KEY=
DOUBAO_TTS_APP_ID=
DOUBAO_TTS_CLUSTER=volcano_tts
DOUBAO_TTS_VOICE=zh_female_shuangkuaisisi_moon_bigtts
