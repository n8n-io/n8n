# Local n8n runtime settings for the video clip workflow.
# Copy this file to .env.video-clip and fill in the real Doubao/Volcengine values.

VIDEO_CLIP_REPO_DIR=/Users/stephenqiu/Desktop/Repository/n8n
VIDEO_CLIP_JOBS_DIR=/Users/stephenqiu/Desktop/Repository/n8n/tmp/n8n-video-jobs

# Required so workflow expressions can read $env.* values.
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# Required so Code nodes can save uploads and run the local composer script.
NODE_FUNCTION_ALLOW_BUILTIN=fs,child_process

# Doubao/Volcengine LLM settings.
DOUBAO_LLM_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
DOUBAO_LLM_API_KEY=
DOUBAO_LLM_MODEL=
DOUBAO_LLM_TEMPERATURE=0.7
# Existing Ark-style env names are also accepted:
# ARK_API_KEY=
# ARK_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_MODEL_NAME=

# Doubao/Volcengine TTS settings.
DOUBAO_TTS_URL=
DOUBAO_TTS_API_KEY=
DOUBAO_TTS_APP_ID=
DOUBAO_TTS_CLUSTER=volcano_tts
DOUBAO_TTS_RESOURCE_ID=seed-tts-2.0
# Required only when selecting voice-clone presets such as S_H3coZls22.
DOUBAO_TTS_CLONE_RESOURCE_ID=
DOUBAO_TTS_VOICE=zh_female_shuangkuaisisi_moon_bigtts

# Doubao/Volcengine AI podcast service 10028.
# In live validation, the WebSocket resource accepted by this AppID is 10050.
DOUBAO_AI_PODCAST_URL=wss://openspeech.bytedance.com/api/v3/sami/podcasttts
DOUBAO_AI_PODCAST_API_KEY=
DOUBAO_AI_PODCAST_APP_ID=2152902662
# Optional compatibility headers for the podcast WebSocket service.
DOUBAO_AI_PODCAST_APP_KEY=aGjiRDfUWi
DOUBAO_AI_PODCAST_ACCESS_KEY=
DOUBAO_AI_PODCAST_RESOURCE_ID=volc.service_type.10050
DOUBAO_AI_PODCAST_SPEAKER_A=zh_male_dayi_v2_saturn_bigtts
DOUBAO_AI_PODCAST_SPEAKER_B=zh_female_mizai_v2_saturn_bigtts
# Official package baseline: 10亿 token / 70000元 = 70元/百万 token.
DOUBAO_AI_PODCAST_PRICE_PER_MILLION_TOKENS=70
VIDEO_CLIP_SUBTITLE_FALLBACK=estimated

# Natural pause inserted between generated dialogue segments.
VIDEO_CLIP_DIALOGUE_PAUSE_MS=180

# Presentation AI Podcast workflow.
# Current MVP supports PDF input with PyMuPDF (`python3 -m pip install pymupdf`).
# PPTX upload returns a clear unsupported-file message and will be enabled later.
PRESENTATION_PAGE_PAUSE_SECONDS=0.3
PRESENTATION_VIDEO_WIDTH=1920
PRESENTATION_VIDEO_HEIGHT=1080
PRESENTATION_VIDEO_FPS=30
PRESENTATION_PYTHON_BIN=python3
