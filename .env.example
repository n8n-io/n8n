# n8n 环境变量示例（复制为 .env 后按需修改）
# 文档: https://docs.n8n.io/hosting/environment-variables/

# 基础（Node 堆大小，单位 MB，可避免 build/typecheck OOM）
# NODE_OPTIONS=--max-old-space-size=8192
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_LOG_LEVEL=debug
N8N_DEFAULT_LOCALE=zh-CN

# 数据库（PostgreSQL 示例）
# DB_TYPE=postgresdb
# DB_POSTGRESDB_HOST=localhost
# DB_POSTGRESDB_PORT=5432
# DB_POSTGRESDB_DATABASE=n8n
# DB_POSTGRESDB_USER=postgres
# DB_POSTGRESDB_PASSWORD=your_password

# 加密（首次运行会自动生成，务必持久化）
# N8N_ENCRYPTION_KEY=

# 敏感项可从文件读取（更安全）：使用 变量名_FILE=文件路径
# 例: DB_POSTGRESDB_PASSWORD_FILE=/run/secrets/postgres_password
