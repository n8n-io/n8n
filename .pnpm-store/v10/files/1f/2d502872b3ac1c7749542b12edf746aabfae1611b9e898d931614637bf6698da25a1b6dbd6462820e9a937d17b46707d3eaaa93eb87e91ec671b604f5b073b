{"version":3,"file":"index.js","sources":["../../../libs/messages/src/core.ts","../../../libs/messages/src/types.ts","../src/constants.ts","../src/index.ts"],"sourcesContent":["import type {MessageAction, MessageCallback, MessageData, MessageResponder} from './types';\n\n/** Sends an action message to the target window at the target origin. */\nexport function sendMessage<T extends MessageAction>(\n  action: T,\n  targetWindow: Window,\n  targetOrigin: string | null,\n  data?: MessageData<T>,\n) {\n  if (targetOrigin) targetWindow.postMessage({action, ...data}, {targetOrigin});\n}\n\n/** Sends an action message to the target window at any origin. */\nexport function broadcastMessage<T extends MessageAction>(\n  action: T,\n  targetWindow: Window,\n  data?: MessageData<T>,\n) {\n  sendMessage(action, targetWindow, '*', data);\n}\n\n/**\n * Listens for action messages from the allowed origin and calls the callback upon receipt.\n * Returns a function that halts the listening.\n */\nexport function listenForMessage<T extends MessageAction>(\n  action: T,\n  isAllowedOrigin: (origin: string) => boolean,\n  callback: MessageCallback<T>,\n) {\n  const listener = ({data, source, origin}: MessageEvent) => {\n    if (!isAllowedOrigin(origin) || !source) return;\n    if (data.action === action) {\n      callback(data, source, origin);\n    }\n  };\n  window.addEventListener('message', listener);\n  return () => window.removeEventListener('message', listener);\n}\n\n/**\n * Listens for an action message from the allowed origin and calls the callback upon receipt. Only\n * listens once. Returns a function that halts the listening.\n */\nexport function listenForMessageOnce<T extends MessageAction>(\n  action: T,\n  isAllowedOrigin: (origin: string) => boolean,\n  callback: (data: MessageData<T>, source: MessageEventSource, origin: string) => void,\n) {\n  const listener = ({data, source, origin}: MessageEvent) => {\n    if (!isAllowedOrigin(origin) || !source) return;\n    if (data.action === action) {\n      window.removeEventListener('message', listener);\n      callback(data, source, origin);\n    }\n  };\n  window.addEventListener('message', listener);\n  return () => window.removeEventListener('message', listener);\n}\n\n/**\n * Listens for action messages from the allowed origin and responds with a message of a different\n * action. Returns a function that halts the listening.\n */\nexport function respondToMessage<T extends MessageAction, W extends MessageAction>(\n  toAction: T,\n  withAction: W,\n  isAllowedOrigin: (origin: string) => boolean,\n  withData?: MessageResponder<T, W>,\n) {\n  return listenForMessage(toAction, isAllowedOrigin, (data, source, origin) => {\n    const response = withData?.(data);\n    source.postMessage({action: withAction, ...response}, {targetOrigin: origin});\n  });\n}\n\n/**\n * Listens for an action message from the allowed origin and responds with a message of a different\n * action. Only responds once. Returns a function that halts the listening.\n */\nexport function respondToMessageOnce<T extends MessageAction, W extends MessageAction>(\n  toAction: T,\n  withAction: W,\n  isAllowedOrigin: (origin: string) => boolean,\n  withData?: MessageResponder<T, W>,\n) {\n  return listenForMessageOnce(toAction, isAllowedOrigin, (data, source, origin) => {\n    const response = withData?.(data);\n    source.postMessage({action: withAction, ...response}, {targetOrigin: origin});\n  });\n}\n","export enum MessageAction {\n  ACK = 'ack',\n  API_KEY = 'api_key',\n  CANCEL = 'cancel',\n  CONNECTION_INFO = 'connection_info',\n  READY = 'ready',\n}\n\n/** Information about the API key the user has created. */\nexport type ApiKeyData = {\n  /** The API key value. */\n  key: string;\n};\n\n/** Information about the connection that the user has authorized. */\nexport type ConnectionInfoData = {\n  /** The ID of the organization that was connected. */\n  organizationId: string;\n  /** The ID of the project that was connected. */\n  globalProjectId: string;\n  /** The API key value for making use of this connection. */\n  key: string;\n};\n\ntype ActionMap = {\n  [MessageAction.API_KEY]: ApiKeyData;\n  [MessageAction.CONNECTION_INFO]: ConnectionInfoData;\n};\n\nexport type MessageData<T extends MessageAction> = T extends keyof ActionMap\n  ? ActionMap[T]\n  : undefined;\n\nexport type MessageCallback<T extends MessageAction> = (\n  data: MessageData<T>,\n  source: MessageEventSource,\n  origin: string,\n) => void;\n\nexport type MessageResponder<T extends MessageAction, W extends MessageAction> = (\n  data: MessageData<T>,\n) => MessageData<W>;\n","export const CONNECT_URL = import.meta.env.VITE_CONNECT_URL;\nexport const CONSOLE_URL = import.meta.env.VITE_CONSOLE_URL;\n\nexport const POPUP_WIDTH = 600;\nexport const POPUP_HEIGHT = 650;\n","import {\n  type ConnectionInfoData,\n  MessageAction,\n  listenForMessage,\n  listenForMessageOnce,\n  respondToMessage,\n} from '@pinecone-experience/messages';\nimport {CONNECT_URL, CONSOLE_URL, POPUP_HEIGHT, POPUP_WIDTH} from './constants';\n\n// eslint-disable-next-line no-barrel-files/no-barrel-files\nexport {type ConnectionInfoData} from '@pinecone-experience/messages';\n\n/** Options for rendering the Connect to Pinecone widget. */\nexport type ConnectToPineconeOptions = {\n  /** The ID of the integration being used. */\n  integrationId: string;\n  /** An HTML element into which the widget will be rendered. Default is document.body. */\n  container?: HTMLElement;\n};\n\nfunction renderIframe({integrationId, container = document.body}: ConnectToPineconeOptions) {\n  const iframe = document.createElement('iframe');\n  iframe.src = `${CONNECT_URL}/${integrationId}`;\n  iframe.style.display = 'block';\n  iframe.style.border = '0';\n  iframe.style.width = '500px';\n  iframe.style.height = '230px';\n  iframe.style.margin = '0';\n  iframe.style.padding = '0';\n  container.appendChild(iframe);\n  return () => container.removeChild(iframe);\n}\n\nfunction openPopup(integrationId: string) {\n  const left = (window.screen.width - POPUP_WIDTH) / 2 + (window.screenLeft ?? window.screenX ?? 0);\n  const top = (window.screen.height - POPUP_HEIGHT) / 2 + (window.screenTop ?? window.screenY ?? 0);\n  window.open(\n    `${CONSOLE_URL}/connect/${integrationId}`,\n    '_blank',\n    `width=${POPUP_WIDTH},height=${POPUP_HEIGHT},left=${left},top=${top}`,\n  );\n}\n\nfunction isAllowedOrigin(origin: string) {\n  return origin === CONNECT_URL;\n}\n\nfunction isAllowedConsoleOrigin(origin: string) {\n  return origin === CONSOLE_URL;\n}\n\n/**\n * Renders the \"Connect to Pinecone\" widget in the provided container DOM element. Calls the\n * provided callback with the API key that results from the user completing the flow. Returns a\n * function that will remove the widget from the DOM.\n */\nexport function connectToPinecone(\n  callback: (apiKey: string) => void,\n  options: ConnectToPineconeOptions,\n) {\n  const cleanupReadyListener = respondToMessage(\n    MessageAction.READY,\n    MessageAction.ACK,\n    isAllowedOrigin,\n  );\n\n  const cleanupApiKeyListener = listenForMessageOnce(\n    MessageAction.API_KEY,\n    isAllowedOrigin,\n    ({key}) => callback(key),\n  );\n\n  const cleanupIframe = renderIframe(options);\n\n  return () => {\n    cleanupReadyListener();\n    cleanupApiKeyListener();\n    cleanupIframe();\n  };\n}\n\n/** Options for opening the popup window. */\nexport type ConnectPopupOptions = {\n  /** A callback function that will be called once the user has authorized the connection. */\n  onConnect?: (connectionInfo: ConnectionInfoData) => void;\n  /** A callback function that will be called if the user cancels the connection. */\n  onCancel?: () => void;\n  /** The ID of the integration being used. */\n  integrationId: string;\n};\n\nexport type ConnectPopupReturn = {\n  /**\n   * Opens the popup window. Use this as an on-click handler, or call it in your custom on-click\n   * handler.\n   */\n  open: () => void;\n  /** Cleans up any lingering side effects. */\n  cleanup: () => void;\n};\n\n/**\n * A popup window that that allows the user to login to Pinecone and authorize the connection.\n */\nexport function ConnectPopup({\n  onConnect = () => {},\n  onCancel = () => {},\n  integrationId,\n}: ConnectPopupOptions): ConnectPopupReturn {\n  const cleanupReadyListener = respondToMessage(\n    MessageAction.READY,\n    MessageAction.ACK,\n    isAllowedConsoleOrigin,\n  );\n\n  const cleanupConnectionInfoListener = listenForMessageOnce(\n    MessageAction.CONNECTION_INFO,\n    isAllowedConsoleOrigin,\n    onConnect,\n  );\n\n  const cleanupCancelListener = listenForMessage(\n    MessageAction.CANCEL,\n    isAllowedConsoleOrigin,\n    onCancel,\n  );\n\n  const open = () => openPopup(integrationId);\n\n  const cleanup = () => {\n    cleanupReadyListener();\n    cleanupConnectionInfoListener();\n    cleanupCancelListener();\n  };\n\n  return {open, cleanup};\n}\n"],"names":["listenForMessage","action","isAllowedOrigin","callback","listener","data","source","origin","listenForMessageOnce","respondToMessage","toAction","withAction","withData","response","MessageAction","CONNECT_URL","CONSOLE_URL","POPUP_WIDTH","POPUP_HEIGHT","renderIframe","integrationId","container","iframe","openPopup","left","top","isAllowedConsoleOrigin","connectToPinecone","options","cleanupReadyListener","cleanupApiKeyListener","key","cleanupIframe","ConnectPopup","onConnect","onCancel","cleanupConnectionInfoListener","cleanupCancelListener"],"mappings":"AAyBgB,SAAAA,EACdC,GACAC,GACAC,GACA;AACA,QAAMC,IAAW,CAAC,EAAC,MAAAC,GAAM,QAAAC,GAAQ,QAAAC,QAA0B;AACzD,IAAI,CAACL,EAAgBK,CAAM,KAAK,CAACD,KAC7BD,EAAK,WAAWJ,KACTE,EAAAE,GAAMC,GAAQC,CAAM;AAAA,EAC/B;AAEK,gBAAA,iBAAiB,WAAWH,CAAQ,GACpC,MAAM,OAAO,oBAAoB,WAAWA,CAAQ;AAC7D;AAMgB,SAAAI,EACdP,GACAC,GACAC,GACA;AACA,QAAMC,IAAW,CAAC,EAAC,MAAAC,GAAM,QAAAC,GAAQ,QAAAC,QAA0B;AACzD,IAAI,CAACL,EAAgBK,CAAM,KAAK,CAACD,KAC7BD,EAAK,WAAWJ,MACX,OAAA,oBAAoB,WAAWG,CAAQ,GACrC