    "synckit": "^0.11.11"
  },
  "peerDependenciesMeta": {
    "synckit": {
      "optional": true
    }
  },
  "dependencies": {
    "rolldown": "1.0.0-rc.12"
  },
  "devDependencies": {
    "@sxzz/eslint-config": "^7.8.3",
    "@sxzz/prettier-config": "^2.3.1",
