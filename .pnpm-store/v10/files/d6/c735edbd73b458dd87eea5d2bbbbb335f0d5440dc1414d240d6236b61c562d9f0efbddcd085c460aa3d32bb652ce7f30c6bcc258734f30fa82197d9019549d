  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gugustinette/unrun.git"
  },
  "bugs": {
    "url": "https://github.com/Gugustinette/unrun/issues"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
