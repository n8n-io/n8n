    "moment-timezone": "^0.6.1",
    "nano-jsx": "^0.2.1",
    "playwright": "^1.58.2",
    "preact": "^10.29.0",
    "preact-render-to-string": "^6.6.6",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reflect-metadata": "^0.2.2",
    "synckit": "^0.11.12",
    "test-ecosystem-ci": "^0.0.3",
    "tinyexec": "^1.0.4",
    "tsdown": "0.21.5",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.18",
