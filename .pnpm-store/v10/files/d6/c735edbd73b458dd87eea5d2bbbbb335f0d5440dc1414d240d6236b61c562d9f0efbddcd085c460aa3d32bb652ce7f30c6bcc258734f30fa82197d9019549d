    "vitepress-plugin-group-icons": "^1.7.1",
    "vitest": "4.1.1",
    "vue": "^3.5.31",
    "vue-tsc": "^3.2.6",
    "zod": "^4.3.6"
  },
  "prettier": "@sxzz/prettier-config",
  "scripts": {
    "lint": "eslint --no-cache .",
    "lint:fix": "pnpm run lint --fix",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "pretest": "pnpm run build && node ./scripts/manage-pnpm-override.mjs add",
    "test": "vitest",
    "pretest:browser": "pnpm run build",
    "test:browser": "vitest run --browser --config vitest.browser.config.ts",
    "posttest": "node ./scripts/manage-pnpm-override.mjs remove",
    "pretest:run": "pnpm run build && node ./scripts/manage-pnpm-override.mjs add",
    "test:run": "vitest run",
    "posttest:run": "node ./scripts/manage-pnpm-override.mjs remove",
    "ecosystem-ci": "ecosystem-ci",
    "ecosystem-ci:force": "ecosystem-ci --force",
    "test:update-fixtures": "node ./dist/cli.mjs ./scripts/update-fixtures.ts",
    "benchmark": "tsdown -c benchmark/tsdown.config.ts && node ./benchmark/dist/benchmark.mjs",
    "typecheck": "tsgo --noEmit",
    "format": "prettier --cache --write .",
    "release": "bumpp",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:generate-reference": "node ./dist/cli.mjs ./docs/.vitepress/scripts/generate-reference.ts"
  }
}