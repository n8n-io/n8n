{"version":3,"file":"literal-string.js","sourceRoot":"","sources":["literal-string.ts"],"names":[],"mappings":";AAAA;;;;;;GAMG","sourcesContent":["/**\n * 字串大小寫轉換工具\n * String Case Conversion Utilities\n * \n * 提供字串命名字面量的大小寫轉換工具\n * Provides string naming literal case conversion utilities\n */\n\n/**\n * 將連字符命名字符串轉換為 PascalCase\n * Convert kebab-case string literal to PascalCase\n * \n * @see yargs\n * \n * @example\n * type Result = ITSPascalCase<'foo-bar'>;\n * // type Result = \"FooBar\"\n * \n * @example\n * type Result = ITSPascalCase<'foo-bar-baz'>;\n * // type Result = \"FooBarBaz\"\n */\nexport type ITSPascalCase<S extends string> = string extends S\n\t? string\n\t: S extends `${infer T}-${infer U}`\n\t\t? `${Capitalize<T>}${ITSPascalCase<U>}`\n\t\t: Capitalize<S>;\n\n/**\n * 將連字符命名字符串轉換為 camelCase\n * Convert kebab-case string literal to camelCase\n * \n * @see yargs\n * \n * @example\n * type Result = ITSCamelCase<'foo-bar'>;\n * // type Result = \"fooBar\"\n * \n * @example\n * type Result = ITSCamelCase<'foo-bar-baz'>;\n * // type Result = \"fooBarBaz\"\n */\nexport type ITSCamelCase<S extends string> = string extends S\n\t? string\n\t: S extends `${infer T}-${infer U}`\n\t\t? `${T}${ITSPascalCase<U>}`\n\t\t: S;\n"]}