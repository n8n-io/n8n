  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.0.18",
    "cross-spawn": "^7.0.6",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "rollup-plugin-license": "^3.7.0",
    "tsdown": "^0.21.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
