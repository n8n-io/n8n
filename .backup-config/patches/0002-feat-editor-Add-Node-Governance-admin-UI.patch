+}
+
+.card {
+	padding: var(--spacing-s);
+}
+
+.cardContent {
+	display: flex;
+	flex-direction: column;
+	gap: var(--spacing-xs);
+}
+
+.cardHeader {
+	display: flex;
+	justify-content: space-between;
+	align-items: center;
+}
+
+.titleRow {
+	display: flex;
+	align-items: center;
+	gap: var(--spacing-xs);
+}
+
+.colorDot {
+	width: 12px;
+	height: 12px;
+	border-radius: 50%;
+}
+
+.actions {
+	display: flex;
+	gap: var(--spacing-2xs);
+}
+</style>
diff --git a/packages/frontend/editor-ui/src/features/settings/nodeGovernance/components/CategoryFormModal.vue b/packages/frontend/editor-ui/src/features/settings/nodeGovernance/components/CategoryFormModal.vue
new file mode 100644
