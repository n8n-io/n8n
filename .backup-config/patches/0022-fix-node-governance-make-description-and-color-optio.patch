Subject: [PATCH 22/22] fix(node-governance): make description and color
 optional in category interface

Allow undefined for description and color to match the DTO schema.
---
 packages/cli/src/services/node-governance.service.ts | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/packages/cli/src/services/node-governance.service.ts b/packages/cli/src/services/node-governance.service.ts
index 36f08eb2c0..4ad23af589 100644
--- a/packages/cli/src/services/node-governance.service.ts
+++ b/packages/cli/src/services/node-governance.service.ts
@@ -35,8 +35,8 @@ interface PolicyMatch {
 export interface NodeGovernanceExportCategory {
 	slug: string;
 	displayName: string;
-	description: string | null;
-	color: string | null;
+	description?: string | null;
+	color?: string | null;
 	nodes: string[];
 }
 
