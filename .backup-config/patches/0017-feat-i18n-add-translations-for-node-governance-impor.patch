@@ -3072,6 +3072,15 @@
 	"nodeGovernance.categories.delete.description": "Are you sure you want to delete this category? Nodes assigned to it will become unassigned.",
 	"nodeGovernance.categories.delete.success": "Category deleted successfully",
 	"nodeGovernance.categories.delete.error": "Failed to delete category",
+	"nodeGovernance.categories.export": "Export",
+	"nodeGovernance.categories.export.success": "Categories exported successfully",
+	"nodeGovernance.categories.export.error": "Failed to export categories",
+	"nodeGovernance.categories.import": "Import",
+	"nodeGovernance.categories.import.success": "Categories imported successfully",
+	"nodeGovernance.categories.import.error": "Failed to import categories",
