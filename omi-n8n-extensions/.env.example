# =============================================
# OmiGroup n8n Extensions - Configuration
# =============================================
# Copy this file to .env and fill in the values.

# ─── n8n Core ────────────────────────────────
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678

# REQUIRED: Generate with `openssl rand -hex 32`
N8N_USER_MANAGEMENT_JWT_SECRET=
N8N_ENCRYPTION_KEY=

# Database (use postgres for production)
DB_TYPE=sqlite
# DB_POSTGRESDB_HOST=
# DB_POSTGRESDB_PORT=5432
# DB_POSTGRESDB_DATABASE=n8n
# DB_POSTGRESDB_USER=
# DB_POSTGRESDB_PASSWORD=

# ─── Google OAuth2 (REQUIRED) ───────────────
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:5678/omi/auth/google/callback
OMI_GOOGLE_CLIENT_ID=
OMI_GOOGLE_CLIENT_SECRET=
OMI_GOOGLE_CALLBACK_URL=http://localhost:5678/omi/auth/google/callback

# ─── Domain Whitelist ────────────────────────
# Comma-separated list of allowed email domains
OMI_DOMAIN_WHITELIST=omigroup.com
# Set to false to allow any Google account
OMI_DOMAIN_WHITELIST_ENFORCED=true

# ─── Admin ───────────────────────────────────
# Comma-separated list of admin email addresses
OMI_ADMIN_EMAILS=admin@omigroup.com

# ─── Template Hub ────────────────────────────
OMI_TEMPLATES_ENABLED=true
# Set to true to require admin approval before templates are visible
OMI_TEMPLATES_REQUIRE_APPROVAL=false

# ─── Usage Statistics ────────────────────────
OMI_STATS_ENABLED=true
# How many days to keep detailed execution logs
OMI_STATS_RETENTION_DAYS=90
