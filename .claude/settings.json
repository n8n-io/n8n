{
	"permissions": {
		"allow": [
			"Bash(git log:*)",
			"Bash(git show:*)",
			"Bash(grep:*)",
			"Bash(ls:*)",
			"Bash(pnpm build)",
			"Bash(pnpm lint:*)",
			"Bash(pnpm test:*)",
			"Bash(pnpm typecheck:*)",
			"Bash(popd)",
			"Bash(pushd:*)"
		]
	},
	"hooks": {
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "npx block-no-verify@1.1.2"
					}
				]
			}
		]
	}
}
