# ── Git-backed workflow release demo (instance-pull, CI-driven) ──────────────
#
# Two n8n instances + one "production-workflows" GitHub repo + GitHub Actions.
#   dev  (e.g. :5678) — raises reviews: export -> commit feature branch -> open PR
#   prd  (e.g. :5679) — validates (dry-run) and publishes (apply) via the public API
#
# A GitHub Action runs the standalone CLI against prd:
#   npx @n8n/cli deploy --instance "$PRD_URL" --dry-run --pr <N> .
#
# One-time GitHub prep: create the production-workflows repo, init it with a
# README so `main` exists, set branch protection to require the dry-run check,
# and make a classic PAT with the `repo` scope. Do NOT commit this file once it
# holds a real token.

# ── shared ───────────────────────────────────────────────────────────────────
N8N_INSTANCE_PULL_DEMO=true
# Expose the n8n-packages public-API endpoints (export/import/validate):
N8N_PUBLIC_API_PACKAGES_ENABLED=true

# ── dev instance ─────────────────────────────────────────────────────────────
# INSTANCE_PULL_ROLE=dev
# INSTANCE_PULL_REPO_URL=https://github.com/<owner>/<repo>.git
# INSTANCE_PULL_GH_OWNER=<owner>
# INSTANCE_PULL_GH_REPO=<repo>
# INSTANCE_PULL_GH_TOKEN=<classic-PAT-with-repo-scope>
# INSTANCE_PULL_BRANCH_BASE=main

# ── prd instance ─────────────────────────────────────────────────────────────
# INSTANCE_PULL_ROLE=prd
# INSTANCE_PULL_PUBLIC_URL=https://n8n.prd.com

# ── GitHub Actions secrets (set in the production-workflows repo, NOT here) ───
# PRD_URL       -> mapped to N8N_URL for the CLI
# PRD_API_KEY   -> mapped to N8N_API_KEY (a prd API key with workflow:import scope)
