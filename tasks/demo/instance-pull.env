# Instance-Pull demo — shared GitHub config.
# Fill in the 4 values below, then in two terminals run:
#   ./tasks/demo/start.sh dev      (n8n on :5678, role=dev)
#   ./tasks/demo/start.sh prd      (n8n on :5679, role=prd)
#
# GitHub prep (one-time): create a repo, initialise it with a README so `main`
# exists, and make a Personal Access Token with the classic `repo` scope.
# Do NOT commit this file once it holds a real token.

INSTANCE_PULL_REPO_URL=
INSTANCE_PULL_GH_OWNER=
INSTANCE_PULL_GH_REPO=
INSTANCE_PULL_GH_TOKEN=

# Optional (defaults to main):
# INSTANCE_PULL_BRANCH_BASE=main
